### Variável base
@baseUrl = http://localhost:3001/api

# Observação:
# - O login agora seta JWT em cookie httpOnly (não precisa copiar token).
# - Para POST/PUT/DELETE, o BackEnd exige CSRF (double submit):
#   1) GET /auth/csrf (cria cookie csrfToken e retorna o valor)
#   2) Enviar header X-CSRF-Token com o mesmo valor.


### ==========================================
### 0. CSRF (gera cookie + retorna token)
### ==========================================
# @name csrf
GET {{baseUrl}}/auth/csrf


### ==========================================
### 1. CADASTRO
### ==========================================
POST {{baseUrl}}/auth/register
Content-Type: application/json
X-CSRF-Token: {{csrf.response.body.csrfToken}}

{
  "name": "Sthefany Admin",
  "email": "sthefany@email.com",
  "password": "12345678"
}

### ==========================================
### 2. LOGIN (JWT via cookie httpOnly)
### ==========================================
### 2.1. LOGIN
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-CSRF-Token: {{csrf.response.body.csrfToken}}

{
  "email": "sthefany@email.com",
  "password": "12345678"
}

###

### 2.3. PERFIL (autenticado via cookie, sem Authorization)
GET {{baseUrl}}/auth/profile

### ==========================================
### 3. LISTAR PRODUTOS (público)
### ==========================================
GET {{baseUrl}}/products

### ==========================================
### 4. DETALHE DO PRODUTO
### ==========================================
GET {{baseUrl}}/products/1

### ==========================================
### 5. CRIAR PRODUTO (admin)
### ==========================================
POST {{baseUrl}}/products
Content-Type: application/json
X-CSRF-Token: {{csrf.response.body.csrfToken}}

{
  "name": "Samambaia",
  "description": "Planta pendente exuberante para interiores.",
  "category": "Plantas",
  "price": 200.00,
  "status": "em_estoque",
  "img": "resources/images/samambaia.jpg"
}

### ==========================================
### 6. ATUALIZAR PRODUTO (admin)
### ==========================================
PUT {{baseUrl}}/products/1
Content-Type: application/json
X-CSRF-Token: {{csrf.response.body.csrfToken}}

{
  "price": 120.00
}

### ==========================================
### 7. DELETAR PRODUTO (admin)
### ==========================================
DELETE {{baseUrl}}/products/13
X-CSRF-Token: {{csrf.response.body.csrfToken}}

### ==========================================
### 8. PERFIL (autenticado)
### ==========================================
GET {{baseUrl}}/auth/profile

### ==========================================
### 9. LISTAR PEDIDOS (admin)
### ==========================================
GET {{baseUrl}}/orders

### ==========================================
### 10. CRIAR PEDIDO (autenticado)
### ==========================================
POST {{baseUrl}}/orders
Content-Type: application/json
X-CSRF-Token: {{csrf.response.body.csrfToken}}

{
  "clientName": "Sthefany",
  "clientEmail": "sthefany@verdanza.com",
  "items": [
    {
      "productId": 1,
      "productName": "Pacova",
      "quantity": 2,
      "price": 99.99
    }
  ],
  "total": 199.98
}

### ==========================================
### 11. ATUALIZAR STATUS PEDIDO (admin)
### ==========================================
PUT {{baseUrl}}/orders/1
Content-Type: application/json
X-CSRF-Token: {{csrf.response.body.csrfToken}}

{
  "status": "enviado"
}

### ==========================================
### 12. LISTAR CLIENTES (admin)
### ==========================================
GET {{baseUrl}}/clients

### ==========================================
### 13. BUSCAR CLIENTE POR ID (admin)
### ==========================================
GET {{baseUrl}}/clients/1

### ==========================================
### 14. LOGOUT (limpa cookie httpOnly) 
### ==========================================
POST {{baseUrl}}/auth/logout
X-CSRF-Token: {{csrf.response.body.csrfToken}}